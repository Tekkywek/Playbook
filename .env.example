# Google Sign-In
# Web (Next/browser): uses Firebase signInWithPopup — enable Google provider in Firebase Console; add authorized domains.
# iOS/Android (Expo): Web client ID from Firebase Console → Project settings → Your apps → Web app (OAuth 2.0 client).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# Optional native (recommended for standalone / dev builds):
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional: Gemini / OpenAI keys for weather message polishing
# Note: these are client-exposed (your app calls the model directly).
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_OPENAI_API_KEY=

# Optional: MapLibre style URL for web interactive maps.
# Default: https://demotiles.maplibre.org/style.json
# Example (MapTiler): https://api.maptiler.com/maps/streets/style.json?key=YOUR_KEY
EXPO_PUBLIC_MAP_STYLE_URL=

# Optional: Coach Pro AI (team channel) — serverless function URL or leave empty for stubs
EXPO_PUBLIC_COACH_AI_ENDPOINT=
